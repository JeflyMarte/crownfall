static func _e(id: String, name: String, description: String) -> Dictionary:
	return {
		"id": id,
		"display_name": name,
		"description": description,
		"discovered": true,
	}


static func _s(title: String) -> String:
	return _RT.section(title)


static func _p(term: String) -> String:
	return _RT.proper(term)


static func _em(term: String) -> String:
	return _RT.emph(term)


static func _w(term: String) -> String:
	return _RT.warn(term)


static func _g001() -> String:
	return (
		"属性は 5 種：%s / %s / %s / %s / %s\n" % [
			_em("炎"), _em("氷"), _em("雷"), _em("闇"), _em("聖")
		]
		+ "世界観上はすべて%sの相であり、超自然の魔法ではない（手引き「エルダ」参照）。\n\n" % _p("エルダ")
		+ _s("敵への与ダメ補正") + "\n"
		+ "弱点属性 … ×1.25\n"
		+ "耐性属性 … ×0.75\n"
		+ "それ以外 … ×1.0\n\n"
		+ "属性のない武器は無属性。無属性は弱点・耐性の判定を受けない。\n\n"
		+ _s("属性値") + "\n"
		+ "装備の属性値が 1 以上あると、\n"
		+ "与ダメ × (1 + 属性値 × 1％) が加算される。\n\n"
		+ _s("ダンジョン地形") + "\n"
		+ "ダンジョンの有利属性と一致すると与ダメ ×1.15。\n\n"
		+ _s("属性シナジー（編成）") + "\n"
		+ "同じ属性武器を 2 人で共有 … 与ダメ +10％\n"
		+ "同じ属性武器を 3 人以上で共有 … 与ダメ +15％\n\n"
		+ _w("注意") + " %s ≠ %s。\n" % [_em("炎属性"), _em("炎上")]
		+ "属性はダメージ倍率にのみ影響する。\n"
		+ "炎上はスキルや接頭・接尾ワードが付与する継続ダメージであり別物。"
	)


